#!/usr/bin/env bash

 # Exit on error. Append "|| true" if you expect an error.
set -o errexit
# Exit on error inside any functions or subshells.
set -o errtrace
# Do not allow use of undefined vars. Use ${VAR:-} to use an undefined VAR
set -o nounset
# Catch the error in case command1 fails (but command2 succeeds) in `command1 |command2`
set -o pipefail
# Turn on traces, useful while debugging but commented out by default
# set -o xtrace

# Replace with your headphone's MAC address
HEADPHONES_MAC="04:52:C7:79:8E:6B"

# Start bluetoothctl, then get info of the device, and finally exit.
# `|| true` keeps the script from tripping `errexit`/`pipefail` when the
# headphones are disconnected (grep returns 1 on no match) — otherwise the
# N/A fallback below is unreachable and the script exits 1 every interval,
# which used to leak X11 RENDER resources via i3bar's error rendering path.
battery_level=$(bluetoothctl info ${HEADPHONES_MAC} 2>/dev/null | grep 'Battery Percentage' | cut -d '(' -f2 | cut -d ')' -f1 || true)

# Check if battery level info is available
if [ -z "$battery_level" ]; then
    echo "N/A"
else
    echo "$battery_level"
fi
