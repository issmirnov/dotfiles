{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Needs your attention' --icon=dialog-information --urgency=normal"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "presentation-tools@smirnovlabs-claude-skills": true,
    "skill-codex@skill-codex": true,
    "nonstop@nonstop": true,
    "git-recon@smirnovlabs-claude-skills": true,
    "visual-explainer@visual-explainer-marketplace": true
  },
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "smirnovlabs-claude-skills": {
      "source": {
        "source": "github",
        "repo": "smirnov-labs/claude-skills"
      }
    },
    "skill-codex": {
      "source": {
        "source": "github",
        "repo": "skills-directory/skill-codex"
      }
    },
    "nonstop": {
      "source": {
        "source": "github",
        "repo": "andylizf/nonstop"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "verbose": true
}
